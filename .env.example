# ============================================================
# Content Moderation POC v0.5.0 — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---- LLM Provider (选一个) ----
# 可选: deepseek | openai | anthropic | local | transformers | sglang
LLM_PROVIDER=deepseek

# ---- LLM 模型选择 (每个 provider 可独立指定模型) ----
# DeepSeek: deepseek-chat, deepseek-chat-v3, ...
# OpenAI:   gpt-4o-mini, gpt-4o, gpt-4.1-mini, ...
# Anthropic: claude-3-5-haiku-latest, claude-sonnet-4-6, ...
# 本地:     自行下载的 GGUF 文件名或 HuggingFace 模型 ID

# ---- 方案 1: DeepSeek API (推荐 POC 用) ----
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- 方案 2: OpenAI API / 自定义兼容端点 ----
# 接入自建 vLLM / Ollama / 内部代理等任意 OpenAI 兼容 API：
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=your-key
#   OPENAI_BASE_URL=https://你的端点.com/v1
#   OPENAI_MODEL=你的模型名
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ---- 方案 3: Anthropic API (备选) ----
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ---- 关闭 HTTP 代理 ----
# 如果机器配了全局 HTTP_PROXY/HTTPS_PROXY 但 LLM API 需要直连，
# 设为 true 即可绕过代理（只对 LLM 调用生效）
# LLM_NO_PROXY=true

# ---- 方案 4: 本地 LLM — llama.cpp + Qwen GGUF ----
# 激活: LLM_PROVIDER=local + LOCAL_LLM_ENABLED=true
# 安装: pip install llama-cpp-python
# 下载模型:
#   mkdir -p models
#   wget https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/qwen2.5-1.5b-instruct-q4_k_m.gguf -O models/qwen2.5-1.5b.gguf
# LOCAL_LLM_MODEL=./models/qwen2.5-1.5b.gguf
# LOCAL_LLM_ENABLED=false

# ---- 方案 5: 本地 LLM — HuggingFace transformers (model.generate) ----
# 激活: LLM_PROVIDER=transformers
# 安装: pip install bitsandbytes  (4-bit 量化，推荐)
# 支持任意 CausalLM 模型: Qwen2.5, Llama-3, Mistral 等
# 模型会自动从 HuggingFace 下载到 ~/.cache/huggingface/
# TRANSFORMERS_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# TRANSFORMERS_LLM_LOAD_IN_4BIT=true
# TRANSFORMERS_LLM_DEVICE_MAP=auto  (auto / cpu / cuda:0)

# ---- 方案 6: 本地 LLM — SGLang (RadixAttention + 结构化输出, 最高吞吐) ----
# 激活: LLM_PROVIDER=sglang
# 安装: pip install sglang[all]
# 优势: system prompt 前缀 KV 缓存 → prefill 降低 ~90%
#       json_schema 约束 → 输出一定是合法 JSON
#       连续批处理 → 高并发下吞吐更高
# SGLANG_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# SGLANG_TP_SIZE=1            (tensor parallelism, 多 GPU 时设置)
# SGLANG_MEM_FRACTION=0.85    (GPU 显存使用比例)

# ---- BERT 分类模型 (L2 层, 本地推理) ----
# 默认: KoalaAI/Text-Moderation (2.7GB, 9标签安全分类)
#
# 可以使用 HuggingFace 模型 ID 或本地路径:
#   BERT_MODEL=KoalaAI/Text-Moderation            # HF 模型 (自动下载到 ~/.cache/huggingface/)
#   BERT_MODEL=unitary/toxic-bert                  # 英文专用 (1.3GB)
#   BERT_MODEL=unitary/multilingual-toxic-xlm-roberta  # 多语言 (80MB)
#   BERT_MODEL=/home/me/models/my-bert-model       # 本地路径 (需包含 config.json + 权重文件)
#
# 本地模型目录需要包含以下文件:
#   config.json, pytorch_model.bin (或 model.safetensors),
#   tokenizer_config.json, vocab.txt (或 tokenizer.json)
# BERT_MODEL=KoalaAI/Text-Moderation
# BERT_ENABLED=true

# ---- 嵌入模型 (语义缓存, 本地推理) ----
# EMBED_MODEL=BAAI/bge-small-zh-v1.5

# ---- Redis 共享缓存 (可选, 多 Worker 时推荐) ----
# 不配也能跑 — 自动回退到进程内 TTLCache
# REDIS_URL=redis://localhost:6379
# REDIS_CACHE_TTL=7200

# ---- ChromaDB 语义缓存 ----
# CHROMA_PERSIST_DIR=./data/chroma

# ---- 关键词词典 ----
# KEYWORD_DICT=./data/keywords.json

# ---- 离线反馈飞轮 (Phase 2) ----
# EVENT_STORE_PATH=./data/events.jsonl
# REVIEW_QUEUE_PATH=./data/review_queue.jsonl
# FEEDBACK_ASSETS_DIR=./data/assets
# FINETUNE_STATE_PATH=./data/finetune_state.json
# FINETUNE_LABEL_THRESHOLD=5000
