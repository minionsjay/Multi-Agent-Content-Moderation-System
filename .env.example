# ============================================================
# Content Moderation POC v0.5.0 — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---- LLM API (至少配一个) ----

# DeepSeek (推荐，便宜)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (备选)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (备选)
ANTHROPIC_API_KEY=

# 选择 LLM 后端: deepseek | openai | anthropic | local
LLM_PROVIDER=deepseek

# ---- Local LLM (llama.cpp, 零成本零网络) ----
# 激活方式: LLM_PROVIDER=local
# 前置条件: pip install llama-cpp-python
# 模型下载: wget https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/qwen2.5-1.5b-instruct-q4_k_m.gguf -O ./models/qwen2.5-1.5b.gguf
# LOCAL_LLM_MODEL=./models/qwen2.5-1.5b.gguf
# LOCAL_LLM_ENABLED=false

# ---- BERT Model (L2文本分类) ----
# 默认: unitary/multilingual-toxic-xlm-roberta (80MB, 15+语言)
# 备选: unitary/toxic-bert (英文, 1.3GB) · govtech/lionguard-2 (多语言安全, 1.3B)
# BERT_MODEL=unitary/multilingual-toxic-xlm-roberta
# BERT_ENABLED=true

# ---- Embedding Model (文本向量化) ----
# EMBED_MODEL=BAAI/bge-small-zh-v1.5

# ---- Redis (L0b 共享缓存, 可选) ----
# 不配也能跑 — 自动回退到本地TTLCache
# REDIS_URL=redis://localhost:6379
# REDIS_CACHE_TTL=7200

# ---- ChromaDB (L1 语义缓存) ----
# CHROMA_PERSIST_DIR=./data/chroma

# ---- 关键词词典 ----
# KEYWORD_DICT=./data/keywords.json

# ---- 离线反馈飞轮 ----
# EVENT_STORE_PATH=./data/events.jsonl
# REVIEW_QUEUE_PATH=./data/review_queue.jsonl
# FEEDBACK_ASSETS_DIR=./data/assets
# FINETUNE_STATE_PATH=./data/finetune_state.json
# FINETUNE_LABEL_THRESHOLD=5000
